generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   Int                  @id @default(autoincrement())
  email                String               @unique
  password             String
  role                 Role                 @default(USER)
  createdAt            DateTime             @default(now())
  department           String?
  name                 String?
  updatedAt            DateTime             @updatedAt
  isActive             Boolean              @default(true)
  attendance           Attendance[]
  complianceItems      ComplianceItem[]
  financialReports     FinancialReport[]
  maintenancePerformed MaintenanceLog[]
  expenses             OperationalExpense[]
  stockMovements       StockMovement[]
  tasks                Task[]
  createdTrainings     Training[]           @relation("UserCreatedTrainings")
  softwareSubscriptions SoftwareSubscription[]
}

model Task {
  id               Int      @id @default(autoincrement())
  title            String
  deadline         DateTime
  frequency        String
  responsible      String
  status           String   @default("Pending")
  documentUrl      String?
  category         String
  riskScore        String?  // "LOW", "MEDIUM", "HIGH"
  aiPriorityIndex  Float?
  aiTags           String[]
  userId           Int
  user             User     @relation(fields: [userId], references: [id])
}

model ComplianceItem {
  id               Int      @id @default(autoincrement())
  title            String
  deadline         DateTime
  frequency        String
  responsible      String
  remindDaysBefore Int?
  status           String   @default("Pending")
  documentUrl      String?
  category         String
  notes            String?
  riskScore        String?  // "LOW", "MEDIUM", "HIGH"
  aiPriorityIndex  Float?
  aiTags           String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  userId           Int
  user             User     @relation(fields: [userId], references: [id])
}

model Training {
  id          Int            @id @default(autoincrement())
  title       String
  description String?
  startDate   DateTime
  endDate     DateTime
  location    String?
  budgetKES   Int            @default(5000)
  costKES     Int            @default(0)
  status      TrainingStatus @default(SCHEDULED)
  createdById Int
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  attendees   Attendance[]
  createdBy   User           @relation("UserCreatedTrainings", fields: [createdById], references: [id])
}

model Attendance {
  id          Int          @id @default(autoincrement())
  attended    Boolean      @default(false)
  userId      Int
  trainingId  Int
  createdAt   DateTime     @default(now())
  training    Training     @relation(fields: [trainingId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  certificate Certificate?

  @@unique([userId, trainingId])
}

model Certificate {
  id            Int        @id @default(autoincrement())
  certificateNo String     @unique
  issueDate     DateTime   @default(now())
  fileUrl       String?
  attendanceId  Int        @unique
  attendance    Attendance @relation(fields: [attendanceId], references: [id])
}

model Vendor {
  id              Int                  @id @default(autoincrement())
  name            String               @unique
  category        String
  contactPerson   String?
  phone           String?
  createdAt       DateTime             @default(now())
  maintenanceLogs MaintenanceLog[]
  expenses        OperationalExpense[]
}

model Asset {
  id           Int              @id @default(autoincrement())
  name         String
  type         String
  serialNumber String?
  purchaseDate DateTime?
  status       String           @default("OPERATIONAL")
  createdAt    DateTime         @default(now())
  maintenance  MaintenanceLog[]
}

model MaintenanceLog {
  id              Int       @id @default(autoincrement())
  assetId         Int
  vendorId        Int?
  serviceDate     DateTime  @default(now())
  nextServiceDate DateTime?
  description     String
  cost            Float     @default(0)
  performedById   Int
  asset           Asset     @relation(fields: [assetId], references: [id])
  performedBy     User      @relation(fields: [performedById], references: [id])
  vendor          Vendor?   @relation(fields: [vendorId], references: [id])
}

model InventoryItem {
  id          Int             @id @default(autoincrement())
  name        String          @unique
  sku         String?         @unique
  category    String
  quantity    Int             @default(0)
  minQuantity Int             @default(5)
  unitPrice   Float           @default(0)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  movements   StockMovement[]
}

model StockMovement {
  id            Int           @id @default(autoincrement())
  itemId        Int
  type          String
  quantity      Int
  reason        String?
  performedById Int
  createdAt     DateTime      @default(now())
  item          InventoryItem @relation(fields: [itemId], references: [id])
  performedBy   User          @relation(fields: [performedById], references: [id])
}

model OperationalExpense {
  id          Int      @id @default(autoincrement())
  category    String
  description String
  amount      Float
  date        DateTime @default(now())
  createdById Int
  vendorId    Int?
  createdBy   User     @relation(fields: [createdById], references: [id])
  vendor      Vendor?  @relation(fields: [vendorId], references: [id])
}

model FinancialReport {
  id              Int      @id @default(autoincrement())
  month           String
  totalExpenses   Float
  maintenanceCost Float
  inventoryValue  Float
  generatedById   Int
  createdAt       DateTime @default(now())
  generatedBy     User     @relation(fields: [generatedById], references: [id])
}

model SoftwareSubscription {
  id              Int      @id @default(autoincrement())
  name            String
  provider        String?
  billingCycle    String   @default("MONTHLY") // e.g., "MONTHLY", "ANNUALLY"
  cost            Float
  nextBillingDate DateTime
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          Int
  user            User     @relation(fields: [userId], references: [id])
}

model AiInsight {
  id          Int      @id @default(autoincrement())
  type        String   // "RISK", "EXPENSE_ANOMALY", "RECOMMENDATION"
  message     String
  severity    String   @default("INFO") // "INFO", "WARNING", "CRITICAL"
  relatedId   Int?     // ID of related entity
  createdAt   DateTime @default(now())
}

model UserBehaviorLog {
  id          Int      @id @default(autoincrement())
  userId      Int
  action      String
  timestamp   DateTime @default(now())
}

enum Role {
  ADMIN
  ACCOUNTANT
  HR
  OPERATIONS_MANAGER
  USER
}

enum TrainingStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
}
