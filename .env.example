# ===========================================
# BHL Management System - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit your .env file to version control.

# ============================================
# 1. DATABASE CONNECTION (Neon PostgreSQL)
# ============================================
# Get this from your Neon dashboard: https://console.neon.tech
# IMPORTANT:
# - In production runtime on Vercel, use the "pooled" connection string.
# - When running `prisma migrate deploy` / `prisma migrate dev`, you may need the "direct" (non-pooled) connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ============================================
# 2. AUTHENTICATION (NextAuth.js)
# ============================================
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-strong-random-secret-here"

# On Vercel, NEXTAUTH_URL is auto-set via VERCEL_URL.
# Only set for local development:
# NEXTAUTH_URL="http://localhost:3000"

# ============================================
# 3. AI SERVICE (Optional)
# ============================================
# Direct OpenAI key for the grounded in-app assistant.
# If set, the assistant will use OpenAI first, enrich answers with live system context,
# and OCR supported receipt scans or image-only PDFs.
OPENAI_API_KEY="your-openai-api-key"

# Optional model override for the grounded assistant.
# OPENAI_MODEL="gpt-4.1-mini"

# URL of the FastAPI AI microservice (if deployed)
# AI_SERVICE_URL="https://your-ai-service.example.com"

# ============================================
# 4. WHATSAPP REMINDERS (Africa's Talking)
# ============================================
# Used for WhatsApp deadline reminders and manager escalations.
AFRICAS_TALKING_USERNAME="sandbox-or-live-username"
AFRICAS_TALKING_API_KEY="your-africas-talking-api-key"
AFRICAS_TALKING_WHATSAPP_NUMBER="+254700000000"

# Optional overrides if Africa's Talking gives you a custom host/path.
# AFRICAS_TALKING_WHATSAPP_BASE_URL="https://chat.africastalking.com"
# AFRICAS_TALKING_WHATSAPP_MESSAGE_PATH="/message/send"

# Public app URL for deep-links inside WhatsApp messages.
# If omitted, NEXTAUTH_URL or VERCEL_URL will be used.
# APP_BASE_URL="https://your-app.vercel.app"

# Protects the scheduled reminder route.
CRON_SECRET="generate-a-strong-random-secret-here"

# Protects the inbound WhatsApp webhook route.
WHATSAPP_INTAKE_SECRET="generate-a-second-random-secret-here"

# ============================================
# 5. DOCUMENT REGISTRY STORAGE
# ============================================
# Local development keeps private files on disk by default.
# To force local mode explicitly:
# DOCUMENT_STORAGE_MODE="LOCAL"
PRIVATE_STORAGE_ROOT=.storage/documents

# Production can switch the registry to private Vercel Blob storage.
# Set DOCUMENT_STORAGE_MODE to VERCEL_BLOB and add a read-write token.
# DOCUMENT_STORAGE_MODE="VERCEL_BLOB"
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ============================================
# VERCEL DEPLOYMENT CHECKLIST
# ============================================
# In your Vercel project settings, add these env vars:
#   - DATABASE_URL        -> Neon pooled connection string
#   - NEXTAUTH_SECRET     -> Strong random secret (same as above)
#   - NEXTAUTH_URL        -> Your Vercel domain (e.g., https://your-app.vercel.app)
#   - OPENAI_API_KEY
#   - OPENAI_MODEL        -> Optional model override
#   - AFRICAS_TALKING_USERNAME
#   - AFRICAS_TALKING_API_KEY
#   - AFRICAS_TALKING_WHATSAPP_NUMBER
#   - APP_BASE_URL
#   - CRON_SECRET
#   - WHATSAPP_INTAKE_SECRET
#   - DOCUMENT_STORAGE_MODE=VERCEL_BLOB
#   - BLOB_READ_WRITE_TOKEN
#
# DO NOT add:
#   - NODE_ENV (Vercel sets this to "production" automatically)
#   - VERCEL_URL (Vercel sets this automatically)

