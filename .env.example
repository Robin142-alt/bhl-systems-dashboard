# ===========================================
# BHL Management System - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# NEVER commit your .env file to version control.

# ============================================
# 1. DATABASE CONNECTION (Neon PostgreSQL)
# ============================================
# Get this from your Neon dashboard: https://console.neon.tech
# IMPORTANT: Use the "pooled" connection string for serverless (Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Direct connection URL (used by Prisma for migrations / db push)
# Use the "direct" (non-pooled) connection string from Neon
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ============================================
# 2. AUTHENTICATION (NextAuth.js)
# ============================================
# Generate a strong secret: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-strong-random-secret-here"

# On Vercel, NEXTAUTH_URL is auto-set via VERCEL_URL.
# Only set for local development:
# NEXTAUTH_URL="http://localhost:3000"

# ============================================
# 3. AI SERVICE (Optional)
# ============================================
# URL of the FastAPI AI microservice (if deployed)
# AI_SERVICE_URL="https://your-ai-service.example.com"

# ============================================
# VERCEL DEPLOYMENT CHECKLIST
# ============================================
# In your Vercel project settings, add these env vars:
#   - DATABASE_URL        → Neon pooled connection string
#   - DIRECT_URL          → Neon direct connection string
#   - NEXTAUTH_SECRET     → Strong random secret (same as above)
#   - NEXTAUTH_URL        → Your Vercel domain (e.g., https://your-app.vercel.app)
#
# DO NOT add:
#   - NODE_ENV (Vercel sets this to "production" automatically)
#   - VERCEL_URL (Vercel sets this automatically)
